DISCORD_TOKEN=your_discord_bot_token

# Optional — override GPT4All model name and path
GPT4ALL_MODEL_NAME=Meta-Llama-3-8B-Instruct.Q4_0.gguf
GPT4ALL_MODEL_PATH=~/AppData/Local/nomic.ai/GPT4All/

